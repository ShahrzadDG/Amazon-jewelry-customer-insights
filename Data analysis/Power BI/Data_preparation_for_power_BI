ile,columns=[\"parent_asin\", \"brand\", \"average_rating\", \"rating_number\", \"price\", \"rating\",\"timestamp\",\"categories\"])\n","        df=df.dropna(subset=[\"parent_asin\", \"brand\", \"average_rating\", \"rating_number\", \"price\", \"rating\",\"timestamp\",\"categories\"])\n","        df[\"brand\"] = df[\"brand\"].astype(str).str.strip()\n","        df[\"average_rating\"] = pd.to_numeric(df[\"average_rating\"], errors=\"coerce\")\n","        df[\"rating_number\"] = pd.to_numeric(df[\"rating_number\"], errors=\"coerce\")\n","        df[\"price\"] = pd.to_numeric(df[\"price\"], errors=\"coerce\")\n","        df[\"rating\"] = pd.to_numeric(df[\"rating\"], errors=\"coerce\")\n","        df[\"timestamp\"] = pd.to_datetime(df[\"timestamp\"], errors=\"coerce\")\n","        df[\"categories\"] = df[\"categories\"].astype(str).str.strip()\n","        # df[\"categories\"] = df[\"categories\"].apply(lambda x: eval(x) if x.startswith(\"[\") else []) #make a list\n","        df[\"categories\"] = df[\"categories\"].str.findall(r\"'([^']*)'\")\n","        # df[\"gender_group\"] = df[\"categories\"].apply(lambda x: x[1] if len(x) > 1 and x[1] in [\"Women\", \"Men\"] else None)\n","        df[\"Jewelry_type\"] = df[\"categories\"].apply(lambda x: x[-2] if isinstance(x, list) and len(x) >= 2 else None)\n","        df[\"Jewelry_subtype\"] = df[\"categories\"].apply(lambda x: x[-1] if isinstance(x, list) and len(x) >= 1 else None)\n","        df = df.drop(columns=[\"categories\"], errors=\"ignore\")\n","        #to keep only valid values\n","        df = df.dropna(subset=[\"average_rating\", \"rating_number\"])\n","        df = df[df[\"rating_number\"] > 0]\n","        df = df[(df[\"average_rating\"] >= 0) & (df[\"average_rating\"] <= 5)]\n","        df = df[df[\"price\"] > 0.0]\n","        df[\"year\"] = df[\"timestamp\"].dt.year\n","        df[\"month\"] = df[\"timestamp\"].dt.month\n","        df = df.drop(columns=[\"timestamp\"], errors=\"ignore\")\n","        df = df.dr